// ── Blynk credentials ─────────────────────────────
#define BLYNK_TEMPLATE_ID   "TMPL3ey6rQ-At"
#define BLYNK_TEMPLATE_NAME "DOCK"
#define BLYNK_AUTH_TOKEN    "YOUR_TOKEN"   // ⚠️ replace
#define BLYNK_PRINT Serial

#include <WiFi.h>
#include <esp_now.h>
#include <BlynkSimpleEsp32.h>
#include <OneWire.h>
#include <DallasTemperature.h>

// ── WiFi ──────────────────────────────────────────
char ssid[] = "PRANAV";
char pass[] = "12345678";

// ── Pins ──────────────────────────────────────────
#define RPWM        33
#define LPWM        25
#define SwitchOpen  14
#define SwitchClose 13
#define RainSensor  32
#define TEMP_PIN    4

// ── Blynk Virtual Pins ────────────────────────────
#define VPIN_OPEN     V2
#define VPIN_CLOSE    V3
#define VPIN_TEMP     V1
#define VPIN_RAIN     V0
#define VPIN_OVERRIDE V4

// ── Temperature ───────────────────────────────────
OneWire oneWire(TEMP_PIN);
DallasTemperature sensors(&oneWire);
BlynkTimer timer;

// ── ESP-NOW Structures ────────────────────────────
typedef struct {
  int requestOpen;
} Message;

typedef struct {
  int ack;
} AckMessage;

// ── Variables ─────────────────────────────────────
int blynkOpen = 0, blynkClose = 0, blynkOverride = 0;
int droneRequesting = 0;

unsigned long doorOpenTime = 0;
bool doorOpenedByDrone = false;
bool droneInside = false;
bool ackSent = false;

// RSSI thresholds
int RSSI_OPEN_THRESHOLD  = -75;
int RSSI_RESET_THRESHOLD = -90;

// ── ESP-NOW RECEIVE ───────────────────────────────
void onReceive(const uint8_t *mac, const uint8_t *data, int len) {
  Message msg;
  memcpy(&msg, data, sizeof(msg));

  int rssi = WiFi.RSSI();

  Serial.print("Received | RSSI: ");
  Serial.println(rssi);

  // Trigger only when very close
  if (rssi >= RSSI_OPEN_THRESHOLD && !droneInside) {
    droneRequesting = 1;

    // Send ACK once
    if (!ackSent) {
      AckMessage ackMsg;
      ackMsg.ack = 1;

      esp_now_send(mac, (uint8_t *)&ackMsg, sizeof(ackMsg));
      Serial.println("ACK sent");

      ackSent = true;
    }
  }
}

// ── Blynk Handlers ────────────────────────────────
BLYNK_WRITE(VPIN_OPEN) {
  blynkOpen = param.asInt();
  if (blynkOpen) {
    blynkClose = 0;
    Blynk.virtualWrite(VPIN_CLOSE, 0);
  }
}

BLYNK_WRITE(VPIN_CLOSE) {
  blynkClose = param.asInt();
  if (blynkClose) {
    blynkOpen = 0;
    Blynk.virtualWrite(VPIN_OPEN, 0);
  }
}

BLYNK_WRITE(VPIN_OVERRIDE) {
  blynkOverride = param.asInt();
}

// ── Motor Control ─────────────────────────────────
void motorOpen() {
  analogWrite(RPWM, 255);
  analogWrite(LPWM, 0);
}

void motorClose() {
  analogWrite(RPWM, 0);
  analogWrite(LPWM, 255);
}

void motorStop() {
  analogWrite(RPWM, 0);
  analogWrite(LPWM, 0);
}

// ── Sensor Read ───────────────────────────────────
void readSensors() {
  sensors.requestTemperatures();
  float tempC = sensors.getTempCByIndex(0);

  int rainRaw = digitalRead(RainSensor);
  String rainLabel = (rainRaw == LOW) ? "Rain" : "Dry";

  Serial.print("Temp: ");
  Serial.print(tempC);
  Serial.print(" | Rain: ");
  Serial.println(rainLabel);

  if (Blynk.connected()) {
    Blynk.virtualWrite(VPIN_TEMP, tempC);
    Blynk.virtualWrite(VPIN_RAIN, rainLabel);
  }
}

// ── Setup ─────────────────────────────────────────
void setup() {
  Serial.begin(115200);

  pinMode(SwitchOpen, INPUT_PULLUP);
  pinMode(SwitchClose, INPUT_PULLUP);
  pinMode(RainSensor, INPUT_PULLUP);
  pinMode(RPWM, OUTPUT);
  pinMode(LPWM, OUTPUT);

  motorStop();
  sensors.begin();

  WiFi.mode(WIFI_AP_STA);
  WiFi.begin(ssid, pass);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Connected!");

  // ESP-NOW init
  if (esp_now_init() != ESP_OK) {
    Serial.println("ESP-NOW Init Failed");
    return;
  }

  esp_now_register_recv_cb(onReceive);
  Serial.println("ESP-NOW Ready");

  // Blynk
  Blynk.config(BLYNK_AUTH_TOKEN);
  Blynk.connect();

  timer.setInterval(1000L, readSensors);
}

// ── LOOP ──────────────────────────────────────────
void loop() {
  Blynk.run();
  timer.run();

  int stateOpen  = digitalRead(SwitchOpen)  == LOW;
  int stateClose = digitalRead(SwitchClose) == LOW;
  int rainState  = digitalRead(RainSensor)  == LOW;

  int rssi = WiFi.RSSI();

  // 🔄 Reset when drone leaves
  if (rssi <= RSSI_RESET_THRESHOLD) {
    Serial.println("Drone left → Reset system");

    droneInside = false;
    doorOpenedByDrone = false;
    ackSent = false;
  }

  // 🚁 Drone trigger
  if (droneRequesting == 1 && !doorOpenedByDrone && !droneInside) {
    Serial.println("Drone close → Opening door");

    motorOpen();
    doorOpenTime = millis();
    doorOpenedByDrone = true;

    droneRequesting = 0;
  }

  // ⏱ Auto close after 15 sec
  if (doorOpenedByDrone && millis() - doorOpenTime >= 15000) {
    Serial.println("Auto closing");

    motorClose();
    delay(2000);
    motorStop();

    droneInside = true;
  }

  // 🌧 Rain logic (kept from your system)
  if (rainState == 1 && blynkOverride == 0) {
    motorClose();
    return;
  }

  // 🎮 Manual + Blynk control
  if (stateOpen && !stateClose) {
    motorOpen();
  }
  else if (stateClose && !stateOpen) {
    motorClose();
  }
  else if (blynkOpen && !blynkClose) {
    motorOpen();
  }
  else if (blynkClose && !blynkOpen) {
    motorClose();
  }
  else if (!doorOpenedByDrone) {
    motorStop();
  }

  delay(100);
}

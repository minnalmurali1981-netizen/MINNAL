#include <Arduino.h>
#include <esp_now.h>
#include <WiFi.h>

#define LED 2

typedef struct {
  String command;
} Message;

Message msg;
unsigned long lastReceived = 0;

void onReceive(const esp_now_recv_info_t *info, const uint8_t *data, int len) {
  memcpy(&msg, data, sizeof(msg));
  Serial.print("Received: ");
  Serial.println(msg.command);
  lastReceived = millis();
}

void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_STA);
  pinMode(LED, OUTPUT);

  esp_now_init();
  esp_now_register_recv_cb(onReceive);

  Serial.println("Receiver ready.");
}

void loop() {
  // If received within last 2 seconds → blink
  if (millis() - lastReceived < 2000) {
    digitalWrite(LED, HIGH);
    delay(500);
    digitalWrite(LED, LOW);
    delay(500);
  } else {
    digitalWrite(LED, LOW);
  }
}
